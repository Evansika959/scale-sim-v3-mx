# ---------------------------------------------------------------------------
# rundir-accelergy generated artifacts & outputs (everything here is rebuilt
# on every run; only *.py, run_*.sh, clean.sh, README.md and
# accelergy_input/components/ are source).
# ---------------------------------------------------------------------------

# Generated by preprocess.py (architecture + the two driver scripts it rewrites)
accelergy_input/architecture.yaml
create_action_count.sh
run_accelergy.sh
/architecture.yaml

# Generated by create_action_count.py
accelergy_input/action_count.yaml

# Accelergy run dir (results are moved to the run's output dir, e.g. /tmp/<run>_out)
accelergy_output/

# In-repo output dir if a run is pointed here with -o ./output
output/

# SLURM job logs
job_*.out
job_*.err

# Python cache
__pycache__/
*.pyc
